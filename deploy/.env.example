# ╔════════════════════════════════════════════════════════════════╗
# ║  Ship Now — 环境变量模板                                      ║
# ║  复制为 .env 并填入你的值                                     ║
# ╚════════════════════════════════════════════════════════════════╝


# ─── 必填：密钥 ──────────────────────────────────────────────────
JWT_SECRET=              # 随机 base64，用于 JWT 签名
ENCRYPTION_KEY=          # 随机 base64，用于数据加密


# ─── 必填：管理员 ────────────────────────────────────────────────
ROOT_ADMIN_USERNAME=admin@example.com
ROOT_ADMIN_PASSWORD=     # 管理员密码


# ─── 必填：数据库 ────────────────────────────────────────────────
POSTGRES_PASSWORD=       # 数据库密码


# ─── 可选：地址 ──────────────────────────────────────────────────
API_BASE_URL=http://localhost:7130
VITE_API_BASE_URL=http://localhost:7130
APP_PORT=7130


# ─── 可选：Docker 项目名 ─────────────────────────────────────────
COMPOSE_PROJECT_NAME={{PROJECT_NAME}}



